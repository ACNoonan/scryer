#!/usr/bin/env bash
# scryer — control script for scryer launchd services
#
# Symlink to ~/.local/bin/scryer (or any PATH dir):
#   ln -sf "$(pwd)/ops/scripts/scryer" ~/.local/bin/scryer
#
# Operates on every plist matching com.adamnoonan.scryer.*  in
# ~/Library/LaunchAgents/ (proxy daemon, portal HTTP daemon, fetch tapes).
#
# Commands:
#   up              Refresh UI bundle then bootstrap any missing scryer plists
#   down            Bootout all loaded scryer plists
#   deploy          Build release bins, copy to ~/Library/Application Support,
#                   sync plists from ops/launchd/ to ~/Library/LaunchAgents/,
#                   reload KeepAlive daemons. One command per phase ship.
#   status          Show launchctl state for every scryer plist
#   open            Open the portal in your default browser
#   ui-refresh      Rebuild the React UI and rsync to the install location
#   logs <name>     Tail logs for one job (e.g. proxy, portal-server, pyth-tape)
#   kick <name>     launchctl kickstart -k for one job
#
# Conventions match ops/launchd/README.md:
#   binaries:        ~/Library/Application Support/scryer/bin/
#   ui bundle:       ~/Library/Application Support/scryer/portal-ui/
#   logs:            ~/Library/Logs/scryer/<name>.{out,err}.log

set -euo pipefail

REPO_ROOT="${SCRYER_REPO:-$HOME/Documents/scryer}"
LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
SUPPORT_ROOT="$HOME/Library/Application Support/scryer"
PORTAL_URL="http://127.0.0.1:47777/"
UI_DEST="$SUPPORT_ROOT/portal-ui"
UI_SRC="$REPO_ROOT/crates/scryer-portal-shell/ui"
LOG_ROOT="$HOME/Library/Logs/scryer"

uid="$(id -u)"
domain="gui/$uid"

scryer_labels() {
  shopt -s nullglob
  for plist in "$LAUNCH_AGENTS"/com.adamnoonan.scryer.*.plist; do
    basename "$plist" .plist
  done
}

is_loaded() {
  launchctl print "$domain/$1" >/dev/null 2>&1
}

cmd_up() {
  if [[ -d "$UI_SRC" ]]; then
    cmd_ui_refresh
  fi
  loaded_any=0
  while IFS= read -r label; do
    plist="$LAUNCH_AGENTS/$label.plist"
    if is_loaded "$label"; then
      printf "  [ok]   %-50s already loaded\n" "$label"
    else
      if launchctl bootstrap "$domain" "$plist" 2>/dev/null; then
        printf "  [up]   %-50s loaded\n" "$label"
        loaded_any=1
      else
        printf "  [fail] %-50s bootstrap failed\n" "$label"
      fi
    fi
  done < <(scryer_labels)
  if [[ $loaded_any -eq 0 ]]; then
    echo "(everything was already up)"
  fi
}

cmd_down() {
  while IFS= read -r label; do
    if is_loaded "$label"; then
      if launchctl bootout "$domain/$label" 2>/dev/null; then
        printf "  [down] %-50s unloaded\n" "$label"
      else
        printf "  [fail] %-50s bootout failed\n" "$label"
      fi
    else
      printf "  [skip] %-50s not loaded\n" "$label"
    fi
  done < <(scryer_labels)
}

cmd_status() {
  while IFS= read -r label; do
    if out=$(launchctl print "$domain/$label" 2>/dev/null); then
      state=$(echo "$out" | awk -F' = ' '/^\tstate /{print $2; exit}')
      pid=$(echo "$out" | awk -F' = ' '/^\tpid /{print $2; exit}')
      exit_code=$(echo "$out" | awk -F' = ' '/^\tlast exit code /{print $2; exit}')
      printf "  %-50s %-12s pid=%-7s exit=%s\n" \
        "$label" "${state:-unknown}" "${pid:-—}" "${exit_code:-—}"
    else
      printf "  %-50s %s\n" "$label" "not loaded"
    fi
  done < <(scryer_labels)
}

cmd_open() {
  open "$PORTAL_URL"
}

cmd_ui_refresh() {
  if [[ ! -d "$UI_SRC" ]]; then
    echo "[ERROR] UI source not found at $UI_SRC" >&2
    exit 1
  fi
  if ! command -v npm >/dev/null; then
    echo "[ERROR] npm not on PATH; install Node.js or skip ui-refresh" >&2
    exit 1
  fi
  ( cd "$UI_SRC" && npm run --silent build >/dev/null )
  mkdir -p "$UI_DEST"
  rsync -a --delete "$UI_SRC/dist/" "$UI_DEST/"
  size_kb=$(du -sk "$UI_DEST" | awk '{print $1}')
  echo "  [ui]   bundled to $UI_DEST (${size_kb} KB)"
}

cmd_logs() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: scryer logs <name>   (e.g. proxy, portal-server, pyth-tape)" >&2
    exit 1
  fi
  shift
  files=( "$LOG_ROOT/$name.out.log" "$LOG_ROOT/$name.err.log" )
  existing=()
  for f in "${files[@]}"; do
    [[ -f "$f" ]] && existing+=("$f")
  done
  if [[ ${#existing[@]} -eq 0 ]]; then
    echo "[ERROR] no logs at $LOG_ROOT/$name.{out,err}.log" >&2
    exit 1
  fi
  exec tail -F "${existing[@]}"
}

cmd_deploy() {
  # Phase 70-D — one-command phase-ship deploy.
  #
  # Workflow steps:
  #   1. cargo build --release for scry, scryer-proxy, scryer-runner.
  #   2. Copy bins to ~/Library/Application Support/scryer/bin/.
  #   3. Sync repo manifests (ops/sources/*.toml) into
  #      ~/Library/Application Support/scryer/manifests/. The runner
  #      reads from this staged dir; the repo dir is the source of
  #      truth.
  #   4. Sync top-level repo plists into ~/Library/LaunchAgents/
  #      (cataloged/ and retired/ subdirs are intentionally excluded —
  #      cataloged/ contains non-scryer-fetch plists that scryer's view
  #      tracks but doesn't own, and retired/ is the migration audit
  #      trail).
  #   5. Reload KeepAlive daemons (proxy, portal-server) so they pick
  #      up the new binary. Tape plists fire on StartInterval and
  #      re-exec the binary on every tick — they auto-pick-up without
  #      a reload.
  local bin_dir="$SUPPORT_ROOT/bin"
  local manifest_src_dir="$REPO_ROOT/ops/sources"
  local manifest_dest_dir="$SUPPORT_ROOT/manifests"
  local plist_src_dir="$REPO_ROOT/ops/launchd"
  local target_dir="$REPO_ROOT/target/release"

  echo "==> deploy: build"
  ( cd "$REPO_ROOT" && cargo build --release -p scry-bin -p scryer-proxy-bin -p scryer-runner-bin )

  echo "==> deploy: copy binaries to $bin_dir"
  mkdir -p "$bin_dir"
  # scryer-runner ships alongside scry + scryer-proxy; the runner-tick
  # plist re-execs the binary on every StartInterval tick so the new
  # binary picks up automatically (KeepAlive reload not required for
  # StartInterval plists).
  for bin in scry scryer-proxy scryer-runner; do
    if [[ ! -x "$target_dir/$bin" ]]; then
      echo "  [fail] $bin not found at $target_dir/$bin (build failed?)" >&2
      exit 1
    fi
    cp "$target_dir/$bin" "$bin_dir/$bin"
    # Strip macOS provenance/quarantine extended attributes that `cp`
    # may copy across, then ad-hoc resign. `xattr -d` alone is not
    # enough: a freshly-copied binary inherits a `com.apple.provenance`
    # assertion that Gatekeeper re-evaluates on every spawn — when the
    # check trips, the OS sends SIGKILL to the *first instruction*, so
    # even the previous `--version` warmup itself was getting killed.
    # `codesign --force --sign -` ad-hoc-signs in place, which replaces
    # the provenance assertion with a stable signature Gatekeeper
    # accepts on every subsequent spawn (this is the standard fix per
    # the Apple developer forums for locally-built binaries).
    xattr -cr "$bin_dir/$bin" 2>/dev/null || true
    if ! codesign --force --sign - "$bin_dir/$bin" 2>/dev/null; then
      printf "  [warn] %-30s codesign failed; binary may be SIGKILLed by Gatekeeper\n" "$bin"
    fi
    if ! "$bin_dir/$bin" --version >/dev/null 2>&1; then
      # --version is fast and side-effect-free; failing it is not
      # automatically fatal (some bins may not implement it), but
      # log so the operator can investigate.
      printf "  [warn] %-30s --version probe failed; binary may need re-sign\n" "$bin"
    fi
    printf "  [bin]  %-30s %s\n" "$bin" "→ $bin_dir/$bin"
  done

  echo "==> deploy: sync runner manifests to $manifest_dest_dir"
  # Sync the full ops/sources/ tree, including subdirectories like
  # data/ (manifest-referenced static files such as pool lists).
  # rsync is preferred for the in-place atomic update + diff
  # reporting; fall back to cp -R if rsync is missing.
  if [[ -d "$manifest_src_dir" ]]; then
    mkdir -p "$manifest_dest_dir"
    if command -v rsync >/dev/null; then
      # Note: NO --delete. We add/update files the repo owns but
      # leave any local-only files alone. If a manifest needs to
      # be removed, retire it from the repo and the operator can
      # also remove it from the staged dir manually.
      rsync -a --itemize-changes \
        --exclude='.DS_Store' \
        "$manifest_src_dir/" "$manifest_dest_dir/" \
        | sed 's/^/  [rsync] /'
    else
      cp -R "$manifest_src_dir/." "$manifest_dest_dir/"
      echo "  [cp -R] $manifest_src_dir/* → $manifest_dest_dir/"
    fi
  else
    echo "  [skip] $manifest_src_dir does not exist"
  fi

  echo "==> deploy: sync plists to $LAUNCH_AGENTS"
  mkdir -p "$LAUNCH_AGENTS"
  shopt -s nullglob
  local synced=0 added=0 skipped_draft=0
  # Phase 114: track which labels had their plist content updated
  # (`[sync]`) so a later stage can bootout+bootstrap them. Without
  # this, launchctl keeps the cached argument list from the previous
  # bootstrap and runs a stale process — the runner-tick `--skip`
  # list collision that prompted this fix.
  local synced_labels=()
  for plist in "$plist_src_dir"/com.adamnoonan.scryer.*.plist; do
    local label
    label=$(basename "$plist" .plist)
    # Defense-in-depth: skip plists that explicitly mark themselves
    # as DRAFT (fetcher pending). The convention is to move DRAFTs
    # into retired/ until ready, but this guard catches the case
    # where someone leaves a DRAFT at top-level.
    if head -30 "$plist" | grep -q 'DRAFT — pending'; then
      printf "  [skip] %-50s DRAFT plist — move to retired/ when ready\n" "$label"
      skipped_draft=$((skipped_draft + 1))
      continue
    fi
    # Skip plists declaring a system-level install target. These need
    # root (e.g. disablesleep-watchdog calls `pmset -a`) and must be
    # bootstrapped manually into /Library/LaunchDaemons/. Staging them
    # as user agents creates a permanently-failing duplicate that
    # pollutes `scry status` with a misleading exit=78.
    if grep -q 'Install target: /Library/LaunchDaemons/' "$plist"; then
      printf "  [skip] %-50s system LaunchDaemon — install manually under /Library/LaunchDaemons/\n" "$label"
      continue
    fi
    local dest="$LAUNCH_AGENTS/$label.plist"
    if [[ -e "$dest" ]] && cmp -s "$plist" "$dest"; then
      printf "  [ok]   %-50s already in sync\n" "$label"
      continue
    fi
    local was_present=0
    [[ -e "$dest" ]] && was_present=1
    cp "$plist" "$dest"
    if [[ $was_present -eq 1 ]]; then
      printf "  [sync] %-50s plist updated\n" "$label"
      synced=$((synced + 1))
      synced_labels+=("$label")
    else
      printf "  [add]  %-50s new plist installed\n" "$label"
      added=$((added + 1))
    fi
  done
  if [[ $synced -eq 0 && $added -eq 0 && $skipped_draft -eq 0 ]]; then
    echo "  (all plists already in sync)"
  fi

  # ---- phase 114: reload sync'd plists ----
  #
  # An updated plist sitting in $LAUNCH_AGENTS does NOT replace
  # launchd's in-memory copy. launchctl re-reads the plist on
  # bootstrap; until then the running job uses the cached
  # `arguments`/`EnvironmentVariables`/etc. from the last bootstrap.
  # `kickstart -k` only restarts the *process* (with the cached
  # plist), so a sync'd-but-not-reloaded plist will keep running
  # the previous version's args indefinitely.
  #
  # bootout is async — the label can sit in "shutting down" briefly
  # and the immediate bootstrap rejects with "Operation already in
  # progress". Poll for full unload before bootstrapping.
  if [[ ${#synced_labels[@]} -gt 0 ]]; then
    echo "==> deploy: reload sync'd plists (bootout + bootstrap, plist content changed)"
    for label in "${synced_labels[@]}"; do
      local plist="$LAUNCH_AGENTS/$label.plist"
      if ! is_loaded "$label"; then
        # Not currently loaded — the "load any newly-added" stage
        # below will bootstrap it. Nothing to do here.
        continue
      fi
      launchctl bootout "$domain/$label" 2>/dev/null || true
      # Poll up to ~3s for the unload to settle.
      local i=0
      while is_loaded "$label" && [[ $i -lt 15 ]]; do
        sleep 0.2
        i=$((i + 1))
      done
      if launchctl bootstrap "$domain" "$plist" 2>/dev/null; then
        printf "  [reload] %-48s plist re-read by launchd\n" "$label"
      else
        printf "  [fail]   %-48s bootstrap failed after bootout\n" "$label" >&2
      fi
    done
  fi

  echo "==> deploy: reload KeepAlive daemons"
  # KeepAlive plists pin a long-running process; the OS doesn't re-exec
  # them when the binary on disk changes. StartInterval plists fork a
  # fresh process on every tick and pick up the new binary
  # automatically — no reload needed.
  #
  # Use `launchctl kickstart -k` (kill + restart in one atomic op)
  # instead of bootout+bootstrap. The bootout/bootstrap pair has a
  # race: bootout is async and can leave the label in a "shutting
  # down" state that rejects the immediate bootstrap with "Operation
  # already in progress". kickstart sidesteps the race entirely —
  # but kickstart only restarts the process; if the *plist* changed
  # we already handled that above via the synced_labels reload stage.
  local keepalive_labels=(
    "com.adamnoonan.scryer.proxy"
    "com.adamnoonan.scryer.portal-server"
  )
  for label in "${keepalive_labels[@]}"; do
    local plist="$LAUNCH_AGENTS/$label.plist"
    if [[ ! -e "$plist" ]]; then
      printf "  [skip] %-50s plist not installed\n" "$label"
      continue
    fi
    # If we just bootout+bootstrap'd this label above, the process
    # already restarted with the new binary AND the new plist.
    # Skip the redundant kickstart. The `${arr[@]+...}` form is the
    # set -u safe idiom for "iterate over array, but no-op when
    # array is empty" — bare `${synced_labels[@]}` would trigger
    # `unbound variable` under `set -u` when nothing was sync'd.
    local already_reloaded=0
    for slabel in ${synced_labels[@]+"${synced_labels[@]}"}; do
      if [[ "$slabel" == "$label" ]]; then
        already_reloaded=1
        break
      fi
    done
    if [[ $already_reloaded -eq 1 ]]; then
      printf "  [ok]   %-50s already reloaded above (plist + binary)\n" "$label"
      continue
    fi
    if is_loaded "$label"; then
      if launchctl kickstart -k "$domain/$label" 2>/dev/null; then
        printf "  [kick] %-50s killed + restarted with new binary\n" "$label"
      else
        printf "  [fail] %-50s kickstart failed\n" "$label" >&2
      fi
    else
      # Not currently loaded — bootstrap fresh.
      if launchctl bootstrap "$domain" "$plist" 2>/dev/null; then
        printf "  [up]   %-50s loaded for the first time\n" "$label"
      else
        printf "  [fail] %-50s bootstrap failed\n" "$label" >&2
      fi
    fi
  done

  echo "==> deploy: load any newly-added tape plists"
  # Plists that were added by the sync step above — bootstrap them so
  # they start ticking; existing tape plists are already loaded and
  # will pick up the new binary on their next StartInterval fire.
  while IFS= read -r label; do
    case "$label" in
      com.adamnoonan.scryer.proxy|com.adamnoonan.scryer.portal-server)
        # Already handled in the KeepAlive block.
        continue
        ;;
    esac
    if ! is_loaded "$label"; then
      local plist="$LAUNCH_AGENTS/$label.plist"
      if launchctl bootstrap "$domain" "$plist" 2>/dev/null; then
        printf "  [up]   %-50s loaded for the first time\n" "$label"
      else
        printf "  [fail] %-50s bootstrap failed\n" "$label" >&2
      fi
    fi
  done < <(scryer_labels)

  echo "==> deploy: done"
}

cmd_kick() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo "usage: scryer kick <name>" >&2
    exit 1
  fi
  # Accept either a bare name (proxy, portal-server) or a full label.
  local label="$name"
  if [[ "$label" != com.* ]]; then
    label="com.adamnoonan.scryer.$name"
  fi
  launchctl kickstart -k "$domain/$label"
  echo "  [kick] $label"
}

usage() {
  sed -n '2,30p' "$0" | sed -e 's/^# //' -e 's/^#$//' >&2
  exit 1
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; fi
  shift
  case "$cmd" in
    up)         cmd_up         "$@" ;;
    down)       cmd_down       "$@" ;;
    deploy)     cmd_deploy     "$@" ;;
    status)     cmd_status     "$@" ;;
    open)       cmd_open       "$@" ;;
    ui|ui-refresh|refresh) cmd_ui_refresh "$@" ;;
    logs)       cmd_logs       "$@" ;;
    kick)       cmd_kick       "$@" ;;
    -h|--help)  usage ;;
    *)          echo "unknown command: $cmd" >&2; usage ;;
  esac
}

main "$@"
